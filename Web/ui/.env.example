# ============================================================================
# TEDIO - FRONTEND ENVIRONMENT CONFIGURATION (EXAMPLE)
# ============================================================================
#
# This file contains environment variables for the React frontend.
# Copy this file to .env and adjust values as needed.
#
# ============================================================================

# ───────────────────────────────────────────────────────────────────────────
# Backend API Configuration
# ───────────────────────────────────────────────────────────────────────────
# URL where the backend API is running

# No API URL config needed — Vite proxy handles dev, nginx handles prod.
# Only set this if you need to override the default /api relative path:
# VITE_API_URL=http://localhost:5001/api

# ───────────────────────────────────────────────────────────────────────────
# Notes
# ───────────────────────────────────────────────────────────────────────────
#
# - All environment variables for Vite must be prefixed with VITE_
# - Changes to .env require restarting the dev server
# - In production, these values are baked into the build
#
